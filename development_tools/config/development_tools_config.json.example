  "analyze_duplicate_functions": {
    "use_mtime_cache": true,
    "min_name_similarity": 0.6,
    "min_overall_similarity": 0.7,
    "max_pairs": 50,
    "max_groups": 50,
    "max_candidate_pairs": 20000,
    "max_token_group_size": 200,
    "stop_name_tokens": [
      "get",
      "set",
      "update",
      "create",
      "delete",
      "handle",
      "process",
      "load",
      "save",
      "run",
      "init",
      "main",
      "check",
      "build",
      "fetch",
      "sync",
      "prepare"
    ],
    "weights": {
      "name": 0.45,
      "args": 0.2,
      "locals": 0.2,
      "imports": 0.15
    }
  },
  "analyze_module_refactor_candidates": {
    "max_lines_per_module": 1000,
    "max_functions_per_module": 40,
    "max_total_complexity_per_module": 2000,
    "high_plus_critical_threshold": 5
  },
  "analyze_module_dependencies": {
    "dependency_doc_path": "development_docs/MODULE_DEPENDENCIES_DETAIL.md"
  },
  "analyze_package_exports": {
    "export_patterns": [],
    "expected_exports": {}
  },
  "analyze_config": {
    "config_schema": {},
    "validation_rules": {},
    "expected_config_functions": [
      "get_available_channels",
      "get_channel_class_mapping",
      "get_user_data_dir",
      "get_backups_dir",
      "get_user_file_path",
      "validate_core_paths",
      "validate_ai_configuration",
      "validate_communication_channels",
      "validate_logging_configuration",
      "validate_scheduler_configuration",
      "validate_file_organization_settings",
      "validate_environment_variables",
      "validate_all_configuration",
      "validate_and_raise_if_invalid",
      "print_configuration_report",
      "ensure_user_directory",
      "validate_email_config",
      "validate_discord_config",
      "validate_minimum_config"
    ],
    "required_sections": [
      "PROJECT_ROOT",
      "SCAN_DIRECTORIES",
      "FUNCTION_DISCOVERY",
      "VALIDATION",
      "AUDIT",
      "OUTPUT",
      "QUICK_AUDIT",
      "VERSION_SYNC",
      "WORKFLOW",
      "DOCUMENTATION",
      "AUTO_DOCUMENT",
      "AI_VALIDATION"
    ]
  },
  "backup_policy": {
    "categories": {
      "A": {
        "description": "Recovery-critical runtime data",
        "max_age_days": 30,
        "min_keep": 4,
        "max_keep": 10,
        "local_retention_enabled": true
      },
      "B": {
        "description": "Engineering artifacts",
        "max_age_days": 90,
        "min_keep": 7,
        "max_keep": 30,
        "local_retention_enabled": true
      },
      "C": {
        "description": "Git-canonical tracked assets",
        "max_age_days": null,
        "min_keep": 0,
        "max_keep": 0,
        "local_retention_enabled": false
      }
    },
    "artifact_rules": [
      {
        "name": "core_user_backups",
        "paths": [
          "data/backups/*"
        ],
        "category": "A",
        "enabled": true,
        "ownership": "core",
        "portable": true,
        "producer": "core.backup_manager + core.scheduler",
        "trigger": "scheduled_weekly",
        "restore_path": "core.backup_manager.restore_backup",
        "notes": "Core-owned runtime recovery artifacts"
      },
      {
        "name": "runtime_log_archives",
        "paths": [
          "logs/archive/*",
          "logs/backups/*"
        ],
        "category": "A",
        "enabled": true,
        "ownership": "core",
        "portable": true,
        "producer": "core.logger",
        "trigger": "automatic_rotation",
        "restore_path": "manual_log_restore",
        "notes": "Managed by runtime logging pipeline"
      },
      {
        "name": "devtools_report_archives",
        "paths": [
          "development_tools/reports/archive/**/*",
          "development_tools/reports/jsons/*.json"
        ],
        "category": "B",
        "enabled": true,
        "ownership": "development_tools",
        "portable": true,
        "producer": "development_tools output storage",
        "trigger": "on_command_run",
        "restore_path": "copy_archive_to_active"
      },
      {
        "name": "devtools_domain_json_archives",
        "paths": [
          "development_tools/*/jsons/archive/**/*",
          "development_tools/*/jsons/*_results.json",
          "development_tools/*/jsons/.*_cache.json"
        ],
        "category": "B",
        "enabled": true,
        "ownership": "development_tools",
        "portable": true,
        "producer": "development_tools.save_tool_result/save_tool_cache",
        "trigger": "on_command_run",
        "restore_path": "copy_archive_to_active"
      },
      {
        "name": "generated_docs_archives",
        "paths": [
          "development_docs/archive/**/*",
          "ai_development_docs/archive/**/*"
        ],
        "category": "B",
        "enabled": true,
        "ownership": "development_tools",
        "portable": true,
        "producer": "development_tools docs generators",
        "trigger": "on_docs_generation",
        "restore_path": "copy_archive_to_active"
      },
      {
        "name": "test_and_coverage_artifacts",
        "paths": [
          "development_tools/tests/logs/**/*",
          "development_tools/tests/jsons/archive/**/*",
          "archive/coverage_artifacts/**/*"
        ],
        "category": "B",
        "enabled": true,
        "ownership": "development_tools",
        "portable": true,
        "producer": "development_tools coverage workflows",
        "trigger": "on_coverage_run",
        "restore_path": "copy_archive_to_active"
      },
      {
        "name": "git_canonical_docs_and_code",
        "paths": [
          "core/**/*.py",
          "communication/**/*.py",
          "development_docs/*.md",
          "ai_development_docs/*.md",
          "README.md",
          "TODO.md"
        ],
        "category": "C",
        "enabled": true,
        "ownership": "git",
        "portable": true,
        "producer": "git",
        "trigger": "version_control",
        "restore_path": "git_restore",
        "notes": "Local retention commands must not mutate these files"
      }
    ],
    "restore_drill": {
      "temp_restore_root": "development_tools/reports/backup_drills",
      "report_json_path": "development_tools/reports/jsons/backup_restore_drill_report.json",
      "verification_checks": {
        "required_paths": [
          "users"
        ],
        "min_file_count": 1
      }
    },
    "ownership_map": {
      "core": "User backup creation/restore and runtime backup scheduling",
      "development_tools": "Artifact inventory, retention, and backup drill reporting",
      "git": "Canonical history for tracked code/docs/changelogs"
    }
  },
  "unused_imports": {
    "preferred_backend": "ruff",
    "pylint_command": [
      "python",
      "-m",
      "pylint"
    ],
    "batch_size": 200,
    "pylint_batch_size": 25,
    "ignore_patterns": [],
    "type_stub_locations": [],
    "timeout_seconds": 30
  },
  "static_analysis": {
    "pyright_command": [
      "python",
      "-m",
      "pyright"
    ],
    "pyright_args": [
      "--outputjson"
    ],
    "pyright_project_path": "pyproject.toml",
    "ruff_args": [
      "check",
      ".",
      "--output-format",
      "json"
    ],
    "ruff_config_path": "development_tools/config/ruff.toml",
    "ruff_sync_root_compat": true,
    "ruff_shard_scan": true,
    "ruff_path_shards": [
      ["core"],
      ["communication"],
      ["ui"],
      ["ai"],
      ["user"],
      ["tasks"],
      ["notebook"],
      ["development_tools"],
      ["tests"]
    ],
    "pyright_shard_scan": true,
    "pyright_path_shards": [
      ["core"],
      ["communication"],
      ["ui"],
      ["ai"],
      ["user"],
      ["tasks"],
      ["notebook"],
      ["development_tools"],
      ["tests"]
    ],
    "bandit_shard_scan": true,
    "timeout_seconds": 600
  },
  "quick_status": {
    "core_files": [],
    "key_directories": [],
    "data_source_plugins": {}
  },
  "system_signals": {
    "core_files": [],
    "data_source_plugins": {}
  },
  "fix_function_docstrings": {
    "template_paths": {},
    "doc_targets": {},
    "formatting_rules": {},
    "function_type_detection": {
      "qt_translation": {
        "file_pattern": "ui/generated/",
        "name": "qtTrId"
      },
      "ui_generated": {
        "file_pattern": "ui/generated/",
        "names": [
          "setupUi",
          "retranslateUi"
        ]
      },
      "test_function": {
        "name_patterns": [
          "test_",
          "test"
        ]
      },
      "special_method": {
        "name_pattern": "__.*__"
      },
      "constructor": {
        "name": "__init__"
      },
      "main_function": {
        "name": "main"
      }
    }
  }
}
