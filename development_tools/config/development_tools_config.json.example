{
  "_comment": "Example configuration file for development tools. Make a copy of this in development_tools_config.json in development_tools/config and customize as needed.",
  "project": {
    "name": "YourProjectName",
    "key_files": [
      "run_your_app.py",
      "core/service.py",
      "core/config.py"
    ],
    "core_system_files": [
      ".gitignore",
      "core/config.py",
      "core/service.py",
      "requirements.txt",
      "run_your_app.py"
    ]
  },
  "paths": {
    "project_root": ".",
    "_comment_scan_directories": "Optional. When absent, derived from constants.local_module_prefixes. Add scan_directories to override (e.g. if derivation falls back to defaults).",
    "docs_dir": "development_docs",
    "logs_dir": "logs",
    "data_dir": "data",
    "ai_docs_dir": "ai_development_docs",
    "development_docs_dir": "development_docs",
    "tests_dir": "tests",
    "tests_data_dir": "tests/data"
  },
  "fix_version_sync": {
    "_comment": "Customize file lists for version synchronization. Category lists (communication_docs, core_docs, etc.) are derived from docs by path prefix; add them only to override.",
    "ai_docs": [],
    "docs": [],
    "cursor_rules": [],
    "documentation_patterns": [
      "*.md"
    ]
  },
  "quick_audit": {
    "_comment": "Customize audit behavior",
    "run_function_audit": true,
    "run_dependency_audit": true,
    "run_documentation_audit": true,
    "run_validation": true,
    "save_results": true,
    "results_file": "development_tools/reports/analysis_detailed_results.json",
    "audit_scripts": [],
    "concise_output": true,
    "prioritize_issues": true
  },
  "audit": {
    "_comment": "Audit mode settings",
    "include_generated_files": false,
    "include_test_files": true,
    "include_legacy_files": false,
    "max_output_lines": 20,
    "save_detailed_results": true,
    "generate_summary": true,
    "highlight_issues": true
  },
  "ai_collaboration": {
    "_comment": "AI collaboration tool settings",
    "concise_output": true,
    "detailed_files": true,
    "actionable_insights": true,
    "context_aware": true,
    "priority_issues": true,
    "integration_mode": true
  },
  "analyze_functions": {
    "_comment": "Function discovery and complexity thresholds",
    "moderate_complexity_threshold": 50,
    "high_complexity_threshold": 100,
    "critical_complexity_threshold": 200,
    "min_docstring_length": 10,
    "handler_keywords": [
      "check",
      "configure",
      "create",
      "delete",
      "get",
      "handle",
      "load",
      "manage",
      "process",
      "save",
      "set",
      "setup",
      "update",
      "validate"
    ],
    "test_keywords": [
      "assert_",
      "check_",
      "test",
      "test_",
      "verify_"
    ],
    "critical_functions": [
      "init",
      "main",
      "run",
      "setup",
      "start",
      "stop",
      "validate"
    ]
  },
  "exclusions": {
    "_comment": "File exclusion patterns for development tools. All patterns are optional - tools will use generic defaults if not provided.",
    "BASE_EXCLUSIONS": [
      "*.pyc",
      "*.pyo",
      "*/generated/*",
      ".git",
      ".idea",
      ".pytest_cache",
      ".ruff_cache",
      ".venv",
      ".vscode",
      "__pycache__",
      "archive",
      "backup*",
      "mhm.egg-info",
      "scripts",
      "scripts/*",
      "scripts/**/*",
      "tests/__pycache__",
      "tests/ai/results",
      "tests/coverage_html",
      "venv"
    ],
    "tool_exclusions": {},
    "context_exclusions": {
      "production": [
        "development_tools/*",
        "tests/*",
        "scripts/*"
      ],
      "development": [
        "*/data/*",
        "*/logs/*"
      ],
      "testing": [
        "*/generated/*",
        "*/data/*"
      ]
    },
    "generated_files": [
      "ai_development_docs/AI_FUNCTION_REGISTRY.md",
      "ai_development_docs/AI_MODULE_DEPENDENCIES.md",
      "development_docs/DIRECTORY_TREE.md",
      "development_docs/FUNCTION_REGISTRY_DETAIL.md",
      "development_docs/LEGACY_REFERENCE_REPORT.md",
      "development_docs/MODULE_DEPENDENCIES_DETAIL.md",
      "development_docs/TEST_COVERAGE_EXPANSION_PLAN.md",
      "development_docs/UNUSED_IMPORTS_REPORT.md",
      "development_tools/AI_PRIORITIES.md",
      "development_tools/AI_STATUS.md",
      "development_tools/consolidated_report.md",
      "development_tools/reports/analysis_detailed_results.json",
      "ui/generated/*"
    ],
    "base_exclusion_shortlist": [
      "*.log",
      ".pytest_cache/",
      ".ruff_cache/",
      ".venv/",
      "__pycache__/",
      "coverage_html/",
      "data/",
      "htmlcov/",
      "logs/",
      "mhm.egg-info/",
      "resources/",
      "scripts/",
      "tests/ai/results/",
      "tests/coverage_html/",
      "venv/"
    ],
    "historical_preserve_files": [
      "archive/",
      "*_history/",
      "logs/"
    ]
  },
  "validation": {
    "_comment": "Validation thresholds and warning settings",
    "documentation_coverage_threshold": 80.0,
    "moderate_complexity_warning": 50,
    "high_complexity_warning": 100,
    "critical_complexity_warning": 200,
    "duplicate_function_warning": true,
    "missing_docstring_warning": true,
    "critical_issues_first": true
  },
  "error_handling": {
    "_comment": "Error handling patterns for analyze_error_handling.py. Customize decorator names, exception classes, and handler functions for your project.",
    "decorator_names": [
      "@handle_errors",
      "handle_errors",
      "error_handler"
    ],
    "exception_base_classes": [
      "AIError",
      "CommunicationError",
      "ConfigurationError",
      "DataError",
      "MHMError",
      "ValidationError"
    ],
    "error_handler_functions": [
      "handle_ai_error",
      "handle_communication_error",
      "handle_configuration_error",
      "handle_file_error",
      "handle_network_error",
      "handle_validation_error",
      "safe_file_operation"
    ],
    "generic_exceptions": {
      "_comment": "Maps generic Python exceptions to project-specific exception classes",
      "Exception": "MHMError",
      "ValueError": "ValidationError or DataError",
      "KeyError": "DataError or ConfigurationError",
      "TypeError": "ValidationError or DataError"
    },
    "critical_function_keywords": {
      "_comment": "Keywords that indicate functions requiring error handling",
      "file_operations": [
        "load",
        "open",
        "read",
        "save",
        "write"
      ],
      "network_operations": [
        "send",
        "receive",
        "connect",
        "request"
      ],
      "data_operations": [
        "parse",
        "serialize",
        "deserialize",
        "validate"
      ],
      "user_operations": [
        "create",
        "update",
        "delete",
        "authenticate"
      ],
      "ai_operations": [
        "generate",
        "process",
        "analyze",
        "classify"
      ]
    },
    "phase1_keywords": {
      "_comment": "Keywords for operation type and priority (phase 1). Customize per project.",
      "file_io": ["open", "read", "write", "save", "load", "os.remove", "shutil.move"],
      "network": ["send", "receive", "connect", "request", "http", "api", "discord", "email"],
      "user_data": ["user_data", "profile", "account", "preferences", "task", "schedule", "checkin"],
      "ai": ["generate", "process", "analyze", "classify", "chatbot", "lm_studio"],
      "entry_point": ["main", "run", "start", "handle", "on_"]
    }
  },
  "output": {
    "_comment": "Output formatting settings",
    "use_emojis": false,
    "show_progress": false,
    "color_output": false,
    "detailed_reports": false,
    "concise_format": true,
    "priority_indicators": true,
    "action_items": true
  },
  "file_patterns": {
    "_comment": "File pattern matching settings. Use exclusions.base_exclusions for exclude patterns (see LIST_OF_LISTS.md §9a).",
    "python_files": "*.py",
    "documentation_files": "*.md",
    "ui_files": "*.ui",
    "config_files": "*.json"
  },
  "path_drift": {
    "_comment": "Project-specific documentation files that intentionally reference legacy paths; excluded from path-drift detection. Include changelog_history files that reference old paths.",
    "legacy_documentation_files": [
      "development_docs/LEGACY_REFERENCE_REPORT.md",
      "development_docs/CHANGELOG_DETAIL.md",
      "ai_development_docs/AI_CHANGELOG.md",
      "development_docs/changelog_history/CHANGELOG_DETAIL_2025_08.md",
      "development_docs/changelog_history/CHANGELOG_DETAIL_2025_09.md",
      "development_docs/changelog_history/CHANGELOG_DETAIL_2025_10.md",
      "development_docs/changelog_history/CHANGELOG_DETAIL_2025_11.md",
      "development_docs/changelog_history/CHANGELOG_DETAIL_2025_12.md"
    ]
  },
  "data_freshness": {
    "_comment": "Project-specific: file paths that have been deleted and must not appear in caches or reports.",
    "known_deleted_files": [
      "development_tools/shared/operations.py",
      "development_docs/SESSION_SUMMARY_2025-12-07.md"
    ]
  },
  "workflow": {
    "_comment": "Workflow behavior settings",
    "audit_first": true,
    "validate_results": true,
    "require_user_approval": false,
    "save_intermediate_results": true,
    "generate_action_items": true,
    "prioritize_by_impact": true
  },
  "documentation": {
    "_comment": "Documentation generation settings",
    "auto_generate": true,
    "preserve_manual_content": true,
    "update_frequency": "on_demand",
    "coverage_target": 95.0,
    "quality_threshold": 80.0
  },
  "auto_document": {
    "_comment": "Auto-documentation settings",
    "enabled": true,
    "template_generation": true,
    "quality_check": true,
    "suggest_improvements": true,
    "preserve_manual_work": true
  },
  "ai_validation": {
    "_comment": "AI validation thresholds",
    "completeness_threshold": 90.0,
    "accuracy_threshold": 85.0,
    "consistency_threshold": 80.0,
    "actionable_threshold": 75.0,
    "critical_issues_weight": 3.0,
    "warning_issues_weight": 1.5,
    "info_issues_weight": 1.0
  },
  "status": {
    "_comment": "Status command settings",
    "check_key_files": true,
    "check_audit_results": true,
    "generate_status_files": true,
    "status_files": {
      "ai_status": "development_tools/AI_STATUS.md",
      "ai_priorities": "development_tools/AI_PRIORITIES.md",
      "consolidated_report": "development_tools/consolidated_report.md"
    }
  },
  "coverage": {
    "_comment": "Coverage regeneration settings. Customize pytest command, config, and artifact directories for your project.",
    "main_workers": {
      "_comment": "Optional worker override for main coverage when run standalone (integer or 'auto'). Null uses built-in behavior.",
      "_example": 8
    },
    "dev_tools_workers": {
      "_comment": "Optional worker override for dev-tools coverage when run standalone (integer or 'auto'). Null uses built-in behavior.",
      "_example": 4
    },
    "main_workers_when_concurrent": {
      "_comment": "Worker cap for main coverage when Tier 3 runs main + dev-tools coverage concurrently.",
      "_example": 6
    },
    "dev_tools_workers_when_concurrent": {
      "_comment": "Worker cap for dev-tools coverage when Tier 3 coverage orchestration is concurrent-enabled (including Windows serialized-coverage guardrail mode).",
      "_example": 6
    },
    "pytest_command": {
      "_comment": "Pytest command as array (e.g., ['python', '-m', 'pytest'] or ['pytest'])",
      "_example": [
        "python",
        "-m",
        "pytest"
      ]
    },
    "pytest_base_args": {
      "_comment": "Base pytest arguments (applied to all coverage runs)",
      "_example": [
        "--cov-report=term-missing",
        "--tb=line",
        "-q",
        "--maxfail=5"
      ]
    },
    "test_directory": {
      "_comment": "Directory containing tests (relative to project root)",
      "_example": "tests/"
    },
    "coverage_config": {
      "_comment": "Path to coverage config file (relative to project root)",
      "_example": "coverage.ini"
    },
    "artifact_directories": {
      "_comment": "Directories for coverage artifacts (relative to project root)",
      "html_output": "htmlcov",
      "archive": "development_tools/reports/archive/coverage_artifacts",
      "logs": "development_tools/tests/logs/coverage_regeneration",
      "dev_tools_html": null
    }
  },
  "legacy_cleanup": {
    "_comment": "Legacy reference cleanup patterns and settings. Customize for your project's legacy code patterns.",
    "deprecation_inventory_file": "development_tools/config/jsons/DEPRECATION_INVENTORY.json",
    "deprecation_inventory_sync_guard": {
      "_comment": "Optional guard: fail legacy analysis/audit when deprecation-like changes are made without updating the inventory file.",
      "enabled": true,
      "trigger_keywords": [
        "deprecated",
        "deprecation",
        "legacy compatibility",
        "legacy",
        "retire",
        "retired",
        "removed",
        "to be removed",
        "obsolete",
        "sunset",
        "shim",
        "fallback",
        "alias",
        "compatibility bridge",
        "migration"
      ]
    },
    "legacy_patterns": {
      "_comment": "Regex patterns to identify legacy code. Categories are arbitrary - use what makes sense for your project.",
      "legacy_compatibility_markers": [
        "# LEGACY COMPATIBILITY:",
        "# LEGACY:"
      ],
      "backup_zip_compat_bridge": [
        "LEGACY COMPATIBILITY: BACKUP_FORMAT=zip ignored in runtime; backup creation is directory-only by policy",
        "LEGACY COMPATIBILITY: Zip backup restore path for historical artifacts\\.",
        "LEGACY COMPATIBILITY: Validating zip backup artifact:",
        "LEGACY COMPATIBILITY: Reading zip backup metadata:"
      ]
    },
    "replacement_mappings": {
      "_comment": "Mappings from old patterns to new patterns for automated cleanup. Leave empty for manual cleanup only."
    },
    "log_locations": {
      "_comment": "Log file/directory paths to scan for legacy references",
      "_example": [
        "logs/",
        "*.log"
      ]
    },
    "skip_extensions": [
      ".md",
      ".txt",
      ".json",
      ".log"
    ]
  },
  "constants": {
    "_comment": "Project-specific constants including documentation metadata and module prefixes. All are optional - tools will use generic defaults if not provided.",
    "default_docs": [
      "README.md",
      "TODO.md",
      "DEVELOPMENT_WORKFLOW.md",
      "development_docs/CHANGELOG_DETAIL.md"
    ],
    "paired_docs": {
      "DEVELOPMENT_WORKFLOW.md": "ai_development_docs/AI_DEVELOPMENT_WORKFLOW.md",
      "ARCHITECTURE.md": "ai_development_docs/AI_ARCHITECTURE.md",
      "DOCUMENTATION_GUIDE.md": "ai_development_docs/AI_DOCUMENTATION_GUIDE.md",
      "logs/LOGGING_GUIDE.md": "ai_development_docs/AI_LOGGING_GUIDE.md",
      "tests/TESTING_GUIDE.md": "ai_development_docs/AI_TESTING_GUIDE.md",
      "development_tools/DEVELOPMENT_TOOLS_GUIDE.md": "development_tools/AI_DEVELOPMENT_TOOLS_GUIDE.md"
    },
    "_comment": "local_module_prefixes is canonical. scan_directories, core_modules, project_directories are derived (see LIST_OF_LISTS.md §6). Add scan_directories to paths, or project_directories/core_modules to constants, to override.",
    "local_module_prefixes": [
      "core",
      "tests",
      "ui"
    ],
    "fix_version_sync_directories": {
      "core": "core/",
      "tests": "tests/",
      "ui": "ui/"
    }
  },
  "documentation_analysis": {
    "_comment": "Documentation analysis settings for analyze_documentation.py",
    "heading_patterns": [
      "## ",
      "### "
    ],
    "placeholder_patterns": [
      "TBD",
      "TODO",
      "to be filled",
      "\\[insert[^\\]]*\\]"
    ],
    "placeholder_flags": [
      "IGNORECASE"
    ],
    "topic_keywords": {
      "Setup & Installation": [
        "install",
        "setup",
        "environment",
        "run"
      ],
      "Development Workflow": [
        "commit",
        "develop",
        "merge",
        "refactor",
        "workflow"
      ],
      "Testing": [
        "test",
        "pytest",
        "coverage",
        "suite"
      ],
      "Architecture": [
        "architecture",
        "module",
        "dependency",
        "structure"
      ],
      "Troubleshooting": [
        "debug",
        "error",
        "fail",
        "failure",
        "issue"
      ],
      "Code Quality": [
        "quality",
        "lint",
        "style",
        "pattern"
      ],
      "Project Structure": [
        "directory",
        "structure",
        "tree"
      ]
    },
    "ignore_rules": []
  },
  "test_markers": {
    "_comment": "Pytest category marker analysis/fix settings. directory_to_marker derived from categories (identity map) when absent.",
    "categories": [
      "unit",
      "integration",
      "behavior",
      "ui"
    ],
    "transient_data_path_markers": [
      "/tmp/",
      "/tmp_pytest_runtime/",
      "pytest-tmp-",
      "pytest-of-"
    ],
    "ai_path_tokens": [
      "ai/test_ai",
      "test_ai"
    ]
  },
  "analyze_function_registry": {
    "_comment": "Audit function registry settings",
    "registry_path": "development_docs/FUNCTION_REGISTRY_DETAIL.md",
    "high_complexity_min": 50,
    "top_complexity": 10,
    "top_undocumented": 5,
    "top_duplicates": 5,
    "error_sample_limit": 5,
    "max_complexity_json": 200,
    "max_undocumented_json": 200,
    "max_duplicates_json": 200
  },
  "analyze_duplicate_functions": {
    "_comment": "Duplicate/similar function analysis settings. consider_body_similarity enables AST body comparison (increases runtime).",
    "use_mtime_cache": true,
    "min_name_similarity": 0.6,
    "min_overall_similarity": 0.7,
    "max_pairs": 50,
    "max_groups": 25,
    "max_candidate_pairs": 20000,
    "max_token_group_size": 200,
    "consider_body_similarity": false,
    "run_body_similarity_on_full_audit": true,
    "body_similarity_min_name_threshold": 0.35,
    "max_body_candidate_pairs": 5000,
    "body_similarity_scope": "same_file",
    "stop_name_tokens": [
      "get",
      "set",
      "update",
      "create",
      "delete",
      "handle",
      "process",
      "load",
      "save",
      "run",
      "init",
      "main",
      "check",
      "build",
      "fetch",
      "sync",
      "prepare"
    ],
    "weights": {
      "name": 0.45,
      "args": 0.2,
      "locals": 0.2,
      "imports": 0.15,
      "body": 0.0
    }
  },
  "analyze_module_dependencies": {
    "_comment": "Audit module dependencies settings",
    "dependency_doc_path": "development_docs/MODULE_DEPENDENCIES_DETAIL.md"
  },
  "analyze_package_exports": {
    "_comment": "Audit package exports settings",
    "export_patterns": [],
    "expected_exports": {}
  },
  "analyze_config": {
    "_comment": "Config validator settings",
    "config_schema": {},
    "validation_rules": {}
  },
  "analyze_ai_work": {
    "_comment": "Validate AI work settings",
    "completeness_threshold": 90.0,
    "accuracy_threshold": 85.0,
    "consistency_threshold": 80.0,
    "actionable_threshold": 75.0,
    "rule_sets": {},
    "rule_set_paths": []
  },
  "backup_policy": {
    "_comment": "Unified backup ownership/retention policy. Keep project-specific paths here so dev-tools code stays portable.",
    "categories": {
      "A": {
        "_comment": "Recovery-critical runtime data (typically core-owned)",
        "description": "Recovery-critical runtime data",
        "max_age_days": 30,
        "min_keep": 4,
        "max_keep": 10,
        "local_retention_enabled": true
      },
      "B": {
        "_comment": "Engineering artifacts managed by development_tools retention command",
        "description": "Engineering artifacts",
        "max_age_days": 90,
        "min_keep": 7,
        "max_keep": 30,
        "local_retention_enabled": true
      },
      "C": {
        "_comment": "Git-owned tracked assets: local retention disabled",
        "description": "Git-canonical tracked assets",
        "max_age_days": null,
        "min_keep": 0,
        "max_keep": 0,
        "local_retention_enabled": false
      }
    },
    "artifact_rules": [
      {
        "name": "core_user_backups",
        "paths": [
          "data/backups/*"
        ],
        "category": "A",
        "enabled": true,
        "ownership": "core",
        "portable": true,
        "producer": "core backup manager",
        "trigger": "scheduled_weekly",
        "restore_path": "core restore API",
        "notes": "Core-owned user backup artifacts"
      },
      {
        "name": "devtools_engineering_artifacts",
        "paths": [
          "development_tools/reports/archive/**/*",
          "development_tools/*/jsons/archive/**/*",
          "development_docs/archive/**/*"
        ],
        "category": "B",
        "enabled": true,
        "ownership": "development_tools",
        "portable": true,
        "producer": "development_tools",
        "trigger": "on_command_run",
        "restore_path": "copy archive file back to active location"
      },
      {
        "name": "git_canonical_assets",
        "paths": [
          "core/**/*.py",
          "development_docs/*.md",
          "ai_development_docs/*.md"
        ],
        "category": "C",
        "enabled": true,
        "ownership": "git",
        "portable": true,
        "producer": "git",
        "trigger": "version_control",
        "restore_path": "git restore"
      }
    ],
    "restore_drill": {
      "_comment": "Restore drill output/report locations",
      "temp_restore_root": "development_tools/reports/backup_drills",
      "report_json_path": "development_tools/reports/jsons/backup_restore_drill_report.json",
      "verification_checks": {
        "required_paths": [
          "users"
        ],
        "min_file_count": 1
      }
    },
    "ownership_map": {
      "core": "Runtime user-data backup/restore ownership",
      "development_tools": "Engineering artifact retention/inventory ownership",
      "git": "Canonical tracked-history ownership"
    }
  },
  "tool_commands": {
    "_comment": "Shared ruff_command for unused_imports and static_analysis. Override per-section if needed.",
    "ruff_command": ["python", "-m", "ruff"]
  },
  "unused_imports": {
    "_comment": "Unused imports checker settings. ruff_command from tool_commands unless overridden.",
    "preferred_backend": "ruff",
    "pylint_command": [
      "python",
      "-m",
      "pylint"
    ],
    "batch_size": 200,
    "pylint_batch_size": 25,
    "ignore_patterns": [],
    "type_stub_locations": [],
    "timeout_seconds": 30
  },
  "static_analysis": {
    "_comment": "Static analysis tool settings (ruff + pyright)",
    "pyright_command": [
      "python",
      "-m",
      "pyright"
    ],
    "pyright_args": [
      "--outputjson"
    ],
    "pyright_project_path": "pyrightconfig.json",
    "ruff_args": [
      "check",
      ".",
      "--output-format",
      "json"
    ],
    "ruff_config_path": "development_tools/config/ruff.toml",
    "ruff_sync_root_compat": true,
    "timeout_seconds": 600
  },
  "quick_status": {
    "_comment": "Quick status settings",
    "core_files": [],
    "key_directories": [],
    "data_source_plugins": {}
  },
  "system_signals": {
    "_comment": "System signals settings",
    "core_files": [],
    "data_source_plugins": {}
  },
  "fix_function_docstrings": {
    "_comment": "Auto document functions settings",
    "template_paths": {},
    "doc_targets": {},
    "formatting_rules": {},
    "function_type_detection": {
      "qt_translation": {
        "file_pattern": "ui/generated/",
        "name": "qtTrId"
      },
      "ui_generated": {
        "file_pattern": "ui/generated/",
        "names": [
          "setupUi",
          "retranslateUi"
        ]
      },
      "test_function": {
        "name_patterns": [
          "test_",
          "test"
        ]
      },
      "special_method": {
        "name_pattern": "__.*__"
      },
      "constructor": {
        "name": "__init__"
      },
      "main_function": {
        "name": "main"
      }
    }
  }
}
