{
  "_comment": "Copy to development_tools/config/development_tools_config.json and customize. Top-level categories match the live config for this repo (see LIST_OF_LISTS.md). Optional sections omitted here fall back to development_tools/config/config.py: documentation_analysis, test_markers, analyze_function_patterns, analyze_ai_work, backup_health, tool_commands, analyze_functions (FUNCTION_DISCOVERY). file_patterns in JSON merges with FILE_PATTERNS via get_file_patterns_config.",
  "project": {
    "name": "YourProject",
    "key_files": [
      "run_app.py",
      "core/service.py",
      "core/config.py"
    ]
  },
  "paths": {
    "project_root": ".",
    "docs_dir": "development_docs",
    "logs_dir": "logs",
    "data_dir": "data",
    "ai_docs_dir": "ai_development_docs",
    "development_docs_dir": "development_docs",
    "tests_dir": "tests",
    "tests_data_dir": "tests/data"
  },
  "fix_version_sync": {
    "ai_docs": [],
    "docs": [],
    "cursor_rules": [
      ".cursor/rules/*.mdc"
    ],
    "documentation_patterns": [
      "*.md"
    ]
  },
  "quick_audit": {
    "run_function_audit": true,
    "run_dependency_audit": true,
    "run_documentation_audit": true,
    "run_validation": true,
    "save_results": true,
    "results_file": "development_tools/reports/analysis_detailed_results.json",
    "audit_scripts": [],
    "concise_output": true,
    "prioritize_issues": true
  },
  "audit": {
    "include_generated_files": false,
    "include_test_files": true,
    "include_legacy_files": false,
    "max_output_lines": 20,
    "save_detailed_results": true,
    "generate_summary": true,
    "highlight_issues": true
  },
  "ai_collaboration": {
    "concise_output": true,
    "detailed_files": true,
    "actionable_insights": true,
    "context_aware": true,
    "priority_issues": true,
    "integration_mode": true
  },
  "validation": {
    "documentation_coverage_threshold": 80.0,
    "duplicate_function_warning": true,
    "missing_docstring_warning": true,
    "critical_issues_first": true
  },
  "error_handling": {
    "decorator_names": [
      "@handle_errors",
      "handle_errors",
      "error_handler"
    ],
    "equivalent_error_decorators": [
      "_guard"
    ],
    "exception_base_classes": [
      "AIError",
      "CommunicationError",
      "ConfigurationError",
      "DataError",
      "FileOperationError",
      "YourProjectError",
      "ValidationError"
    ],
    "error_handler_functions": [
      "handle_ai_error",
      "handle_communication_error",
      "handle_configuration_error",
      "handle_file_error",
      "handle_network_error",
      "handle_validation_error",
      "safe_file_operation"
    ],
    "generic_exceptions": {
      "Exception": "YourProjectError",
      "ValueError": "ValidationError or DataError",
      "KeyError": "DataError or ConfigurationError",
      "TypeError": "ValidationError or DataError"
    },
    "critical_function_keywords": {
      "file_operations": [
        "load",
        "open",
        "read",
        "save",
        "write"
      ],
      "network_operations": [
        "send",
        "receive",
        "connect",
        "request"
      ],
      "data_operations": [
        "parse",
        "serialize",
        "deserialize",
        "validate"
      ],
      "user_operations": [
        "create",
        "update",
        "delete",
        "authenticate"
      ],
      "ai_operations": [
        "generate",
        "process",
        "analyze",
        "classify"
      ]
    },
    "phase1_keywords": {
      "file_io": [
        "open",
        "read",
        "write",
        "save",
        "load",
        "file",
        "json",
        "close",
        "os.remove",
        "shutil.move"
      ],
      "network": [
        "send",
        "receive",
        "connect",
        "request",
        "http",
        "api",
        "discord",
        "email"
      ],
      "user_data": [
        "user_data",
        "profile",
        "account",
        "preferences",
        "task",
        "schedule",
        "checkin"
      ],
      "validation": [
        "validate",
        "check",
        "verify",
        "invalid",
        "missing",
        "required"
      ],
      "scheduling": [
        "schedule",
        "task",
        "reminder",
        "scheduler"
      ],
      "configuration": [
        "config",
        "setting",
        "option"
      ],
      "ui": [
        "ui",
        "dialog",
        "widget",
        "button",
        "qt",
        "pyqt"
      ],
      "ai": [
        "generate",
        "process",
        "analyze",
        "classify",
        "chatbot",
        "lm_studio",
        "ai"
      ],
      "entry_point": [
        "main",
        "run",
        "start",
        "handle",
        "on_",
        "command",
        "handler",
        "clicked"
      ]
    }
  },
  "output": {
    "use_emojis": false,
    "show_progress": false,
    "color_output": false,
    "detailed_reports": false,
    "concise_format": true,
    "priority_indicators": true,
    "action_items": true
  },
  "path_drift": {
    "ignored_path_patterns": [],
    "legacy_documentation_files": []
  },
  "data_freshness": {
    "known_deleted_files": []
  },
  "workflow": {
    "audit_first": true,
    "validate_results": true,
    "require_user_approval": false,
    "save_intermediate_results": true,
    "generate_action_items": true,
    "prioritize_by_impact": true
  },
  "documentation": {
    "auto_generate": true,
    "preserve_manual_content": true,
    "update_frequency": "on_demand",
    "coverage_target": 95.0,
    "quality_threshold": 80.0
  },
  "auto_document": {
    "enabled": true,
    "template_generation": true,
    "quality_check": true,
    "suggest_improvements": true,
    "preserve_manual_work": true
  },
  "ai_validation": {
    "completeness_threshold": 90.0,
    "accuracy_threshold": 85.0,
    "consistency_threshold": 80.0,
    "actionable_threshold": 75.0,
    "critical_issues_weight": 3.0,
    "warning_issues_weight": 1.5,
    "info_issues_weight": 1.0
  },
  "status": {
    "check_key_files": true,
    "check_audit_results": true,
    "generate_status_files": true,
    "status_files": {
      "ai_status": "development_tools/AI_STATUS.md",
      "ai_priorities": "development_tools/AI_PRIORITIES.md",
      "consolidated_report": "development_tools/CONSOLIDATED_REPORT.md"
    }
  },
  "coverage": {
    "main_workers": null,
    "dev_tools_workers": null,
    "main_workers_when_concurrent": 6,
    "dev_tools_workers_when_concurrent": 6,
    "pytest_command": [
      "python",
      "-m",
      "pytest"
    ],
    "pytest_base_args": [
      "--cov-report=term-missing",
      "--tb=line",
      "-q",
      "--maxfail=5"
    ],
    "coverage_config": "development_tools/tests/coverage.ini",
    "artifact_directories": {
      "html_output": "htmlcov",
      "archive": "archive/coverage_artifacts",
      "logs": "development_tools/tests/logs",
      "dev_tools_html": "development_tools/coverage_html_dev_tools"
    }
  },
