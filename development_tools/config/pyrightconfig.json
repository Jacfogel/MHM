{
  "typeCheckingMode": "basic",
  "reportReturnType": "none",
  "reportArgumentType": "warning",
  "reportOptionalMemberAccess": "warning",
  "reportAttributeAccessIssue": "warning",
  "reportGeneralTypeIssues": "warning",
  "reportUnboundVariable": "error",
  "reportUnsupportedDunderAll": "none",
  "ignore": [],
  "exclude": [
    "scripts",
    "scripts/**",
    "ui/generated",
    "ui/generated/**",
    "**/__pycache__",
    "**/node_modules",
    "**/.pytest_cache",
    "**/.venv",
    "**/venv",
    "logs",
    "logs/**",
    "resources",
    "resources/**",
    "archive",
    "archive/**",
    "development_docs",
    "development_docs/**",
    "ai_development_docs",
    "ai_development_docs/**",
    "styles",
    "styles/**",
    "tests/logs",
    "tests/logs/**",
    "tests/data",
    "tests/data/**",
    "tests/temp",
    "tests/temp/**",
    "tests/fixtures",
    "tests/fixtures/**",
    ".git",
    ".pytest_cache",
    ".coverage",
    "*.pyc",
    "*.pyo"
  ]
}
